{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "dev_pipeline_version", "state", "plan_path", "config_path", "project_dir", "iterations", "max", "history", "started_at", "updated_at"],
  "properties": {
    "run_id":                { "type": "string" },
    "dev_pipeline_version":  { "type": "string" },
    "state": {
      "type": "string",
      "enum": ["init", "test_implementation", "red_test", "implementation", "test", "review", "done", "failed"]
    },
    "plan_path":     { "type": "string" },
    "config_path":   { "type": "string" },
    "contract_path": { "type": "string" },
    "spec_path":     { "type": "string" },
    "project_dir":   { "type": "string" },
    "work_root": {
      "description": "Where code is edited and working-tree git bookkeeping happens: the worktree path under --worktree, else equal to project_dir.",
      "type": "string"
    },
    "worktree_branch": {
      "description": "dev-pipeline/<run_id> for a --worktree run, else null.",
      "oneOf": [{ "type": "string" }, { "type": "null" }]
    },
    "worktree_base_ref": {
      "description": "The branch (or, if detached, commit SHA) project_dir was on when --worktree created the worktree; else null.",
      "oneOf": [{ "type": "string" }, { "type": "null" }]
    },
    "tdd_mode":     { "type": "boolean" },
    "red_phase":    { "type": "boolean" },
    "iterations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test", "review"],
      "properties": {
        "test":                { "type": "integer", "minimum": 0 },
        "review":              { "type": "integer", "minimum": 0 },
        "test_implementation": { "type": "integer", "minimum": 0 }
      }
    },
    "max": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test", "review"],
      "properties": {
        "test":                { "type": "integer", "minimum": 1 },
        "review":              { "type": "integer", "minimum": 1 },
        "test_implementation": { "type": "integer", "minimum": 1 }
      }
    },
    "halt_reason": {
      "oneOf": [
        { "type": "string", "enum": ["environment", "iteration-exhausted"] },
        { "type": "null" }
      ]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "ts", "outcome"],
        "properties": {
          "state":        { "type": "string" },
          "ts":           { "type": "string" },
          "outcome":      { "type": "string" },
          "failure_type": {
            "oneOf": [
              { "type": "string", "enum": ["code", "environment"] },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "started_at":  { "type": "string" },
    "updated_at":  { "type": "string" }
  }
}
